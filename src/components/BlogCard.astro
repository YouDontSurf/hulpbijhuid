---
// src/components/BlogCard.astro
interface Props {
  title: string;
  slug: string;
  summary: string;
  date: Date;
  readingTime: number;
  category: string;
}
const { title, slug, summary, date, readingTime, category } = Astro.props;
const formattedDate = date.toLocaleDateString("nl-NL", { year: "numeric", month: "long", day: "numeric" });
---

<article
  class="bg-surface rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow"
  itemscope
  itemtype="https://schema.org/BlogPosting"
>
  <a href={slug} class="block p-6 no-underline">
    <div class="flex items-center gap-2 text-xs text-text-muted mb-3">
      <span class="bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">{category}</span>
      <span>·</span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span>·</span>
      <span>{readingTime} min leestijd</span>
    </div>
    <h2 class="text-lg font-semibold text-text mb-2" itemprop="headline">{title}</h2>
    <p class="text-sm text-text-muted line-clamp-2" itemprop="description">{summary}</p>
  </a>
</article>